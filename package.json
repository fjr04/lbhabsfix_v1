{
  "name": "abs-law-office-final-v18-polish",
  "version": "1.0.18",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node ./scripts/prepare-dist.mjs",
    "html": "html-minifier-terser ./src/index.html -o ./dist/index.html --collapse-whitespace --remove-comments --minify-css true --minify-js true",
    "copy": "node ./scripts/copy-public.mjs",
    "vendor": "node ./scripts/copy-vendor.mjs",
    "images": "node ./scripts/optimize-images.mjs",
    "css": "tailwindcss -i ./src/css/input.css -o ./dist/assets/css/style.min.css --minify",
    "js": "terser ./src/js/main.js -c -m -o ./dist/assets/js/main.min.js",
    "posthtml": "node ./scripts/posthtml.mjs",
    "build": "npm run clean && npm run html && npm run copy && npm run vendor && npm run images && npm run css && npm run js && npm run posthtml",
    "preview": "npx serve -s dist",
    "local": "npm run build && node ./scripts/local-server.mjs",
    "dev:api": "node ./scripts/local-server.mjs"
  },
  "devDependencies": {
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "autoprefixer": "^10.4.20",
    "html-minifier-terser": "^7.2.0",
    "postcss": "^8.4.49",
    "serve": "^14.2.4",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "terser": "^5.36.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
